{
  "name": "raitha-reach",
  "version": "2.0.0",
  "description": "Karnataka Farm-Direct Auction Portal",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5199",
    "dev:server": "node server/index.js",
